{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bezier",
  "version": "0.1.0",
  "identifier": "com.bezier.app",
  "build": {
    "beforeDevCommand": "npm run dev -- -p 3210",
    "devUrl": "http://localhost:3210",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bezier",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
